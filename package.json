{
  "name": "taroflash",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "dev:host": "vp dev --host",
    "dev:full": "run-p -l vite stripe",
    "vite": "vp dev",
    "stripe": "stripe listen --forward-to http://localhost:54321/functions/v1/stripe-webhook",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vp preview",
    "test": "vp test run --coverage",
    "test:watch": "vp test",
    "test:ui": "vp test --ui --coverage",
    "build-only": "vp build",
    "type-check": "vue-tsc --build --force",
    "lint": "oxlint",
    "format": "vp fmt src/",
    "docs:dev": "vitepress dev docs --port 8080",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@lexical/headless": "^0.41.0",
    "@lexical/html": "^0.41.0",
    "@lexical/list": "^0.41.0",
    "@lexical/markdown": "^0.41.0",
    "@lexical/rich-text": "^0.41.0",
    "@lexical/selection": "^0.41.0",
    "@lexical/utils": "^0.41.0",
    "@pinia/colada": "^1.1.0",
    "@stripe/stripe-js": "^9.2.0",
    "@supabase/supabase-js": "^2.101.1",
    "@types/howler": "^2.2.12",
    "body-scroll-lock": "4.0.0-beta.0",
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "lexical": "^0.41.0",
    "luxon": "^3.7.2",
    "oxc-minify": "^0.125.0",
    "pinia": "^3.0.4",
    "ts-fsrs": "^5.3.2",
    "vue": "^3.5.31",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "@intlify/unplugin-vue-i18n": "^6.0.8",
    "@pinia/testing": "^1.0.3",
    "@rushstack/eslint-patch": "^1.16.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node18": "^18.2.6",
    "@types/jsdom": "^21.1.7",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^26.1.0",
    "mimicry-js": "^1.3.0",
    "msw": "^2.12.14",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.1",
    "supabase": "^2.84.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "unplugin-vue-components": "^28.8.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.15",
    "vite-plus": "latest",
    "vite-svg-loader": "^5.1.1",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.15",
    "vue-tsc": "^2.2.12"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
